// lm-collector-reachability-check.groovy
//
// Tests network reachability from this collector to all devices in an auto-balance group.
// Run in: LM Portal → Collector (new one) → Collector Debug → Script tab.
//
// Two ways to prepare this script:
//
//   Mode A  device list pre-filled, credentials empty (default):
//     tools/elm-collector-readiness.sh --id GROUP_ID > /tmp/check.groovy
//
//   Mode B  device list AND LM credentials pre-filled from elm config:
//     tools/elm-collector-readiness.sh --id GROUP_ID --creds > /tmp/check.groovy
//     tools/elm-collector-readiness.sh --id GROUP_ID --creds --profile prod > /tmp/check.groovy
//
//   Mode C  manual: open lm-collector-reachability-check.groovy.j2 and fill in below
//
// INTERPRETING RESULTS:
//   PASS    - connection succeeded
//   FAIL    - connection refused or timed out
//   TIMEOUT - SNMP: port may be reachable but agent dropped the probe (wrong community
//             or silent discard); investigate manually if device should have SNMP
//   -       - protocol not expected for this device (skipped)

import groovy.json.JsonSlurper
import javax.crypto.Mac
import javax.crypto.spec.SecretKeySpec
import java.util.concurrent.*

// ─── Device list ──────────────────────────────────────────────────────────────
// Pre-filled by elm-collector-readiness.sh. Leave as [] to use Mode C credentials path instead.
def DEVICES_JSON = '''
{{ devices_json | default('[]') }}
'''

// ─── LM API credentials (Mode B/C) ───────────────────────────────────────────
// Pre-filled by --creds, or fill in manually for Mode C.
// Remove credentials from this script after use — debug console history may retain them.
def ACCESS_ID    = "{{ access_id | default('') }}"
def ACCESS_KEY   = "{{ access_key | default('') }}"
def ACCOUNT_NAME = "{{ account_name | default('acme') }}"
def GROUP_ID     = {{ group_id | default(0) }}  // auto-balance group ID

// ─── Test timeouts ─────────────────────────────────────────────────────────────
def PING_TIMEOUT_MS = 1500
def TCP_TIMEOUT_MS  = 1000
def SNMP_TIMEOUT_MS = 2000

// ─────────────────────────────────────────────────────────────────────────────
// Implementation — no changes needed below this line
// ─────────────────────────────────────────────────────────────────────────────

// LMv1 HMAC-SHA256 auth header
def lmAuth(accessId, accessKey, method, path, body = "") {
    def epoch = System.currentTimeMillis()
    def data  = "${method}${epoch}${body}${path}"
    def mac   = Mac.getInstance("HmacSHA256")
    mac.init(new SecretKeySpec(accessKey.getBytes("UTF-8"), "HmacSHA256"))
    def sig = mac.doFinal(data.getBytes("UTF-8")).encodeBase64().toString()
    return "LMv1 ${accessId}:${sig}:${epoch}"
}

// HTTP GET against LM REST API
def lmGet(account, path, auth) {
    def url  = new URL("https://${account}.logicmonitor.com/santaba/rest${path}")
    def conn = (HttpURLConnection) url.openConnection()
    conn.setRequestProperty("Authorization", auth)
    conn.setRequestProperty("Content-Type", "application/json")
    conn.setConnectTimeout(15000)
    conn.setReadTimeout(60000)
    conn.connect()
    def code = conn.getResponseCode()
    def body = (code < 400 ? conn.getInputStream() : conn.getErrorStream()).getText("UTF-8")
    conn.disconnect()
    if (code != 200) throw new Exception("LM API HTTP ${code}: ${body}")
    return new JsonSlurper().parseText(body)
}

// Derive protocols from autoProperties (matches elm-collector-readiness.sh logic)
def protocolsFromAutoProps(autoProps) {
    def protos = ["ping"]
    def props  = [:]
    (autoProps ?: []).each { p -> props[p.name] = p.value }
    if (props["auto.snmp.operational"] == "true") protos << "snmp"
    def tcp = (props["auto.network.listening_tcp_ports"] ?: "").split(",") as List
    if ("135" in tcp) protos << "tcp-135"
    if ("22"  in tcp) protos << "tcp-22"
    if ("80"  in tcp) protos << "tcp-80"
    if ("443" in tcp) protos << "tcp-443"
    return protos
}

// ── Device list ───────────────────────────────────────────────────────────────

def slurper = new JsonSlurper()
def devices  = []

def pasted = DEVICES_JSON.trim()
if (pasted.size() > 2 && pasted != "[]") {
    devices = slurper.parseText(pasted)
    println "${devices.size()} devices (pre-filled by elm)"
} else {
    if (!ACCESS_ID || !ACCESS_KEY || GROUP_ID == 0) {
        println "ERROR: render this script with elm-collector-readiness.sh (Mode A)"
        println "       OR set ACCESS_ID, ACCESS_KEY, ACCOUNT_NAME, GROUP_ID (Mode C)"
        return
    }
    println "Querying LM API for devices in collector group ${GROUP_ID}..."
    def path  = "/device/devices?filter=autoBalancedCollectorGroupId:${GROUP_ID}&size=1000&fields=id,displayName,name,autoProperties"
    def auth  = lmAuth(ACCESS_ID, ACCESS_KEY, "GET", path)
    def resp  = lmGet(ACCOUNT_NAME, path, auth)
    devices = resp.data.items.collect { d ->
        [id: d.id, displayName: d.displayName, ip: d.name,
         protocols: protocolsFromAutoProps(d.autoProperties)]
    }
    println "${devices.size()} devices from LM API"
}

if (!devices) {
    println "No devices to test — check group ID or elm output."
    return
}

// ── Connectivity tests ─────────────────────────────────────────────────────────

def pingOk(ip, timeoutMs) {
    try {
        return java.net.InetAddress.getByName(ip).isReachable(timeoutMs)
    } catch (e) { return false }
}

def tcpOk(ip, port, timeoutMs) {
    try {
        def s = new java.net.Socket()
        s.connect(new java.net.InetSocketAddress(ip, port), timeoutMs)
        s.close()
        return true
    } catch (e) { return false }
}

// SNMP reachability probe: sends a minimal SNMPv2c GetRequest (sysDescr OID, community
// "public") via raw UDP. Any response — including an SNMP error or auth rejection —
// means the port is open. A timeout means either the device is unreachable, the
// firewall is silently dropping UDP 161, or the agent silently drops unknown communities.
// TIMEOUT is not necessarily unreachable — see header comment.
def snmpOk(ip, timeoutMs) {
    // SNMPv2c GetRequest: sysDescr (.1.3.6.1.2.1.1.1.0), community "public"
    // Pre-built 43-byte ASN.1/BER packet (verified by hand against RFC 3416)
    def pkt = "302902010104067075626c6963a01c020400000001020100020100300e300c06082b060102010101000500".decodeHex()
    try {
        def sock = new java.net.DatagramSocket()
        sock.setSoTimeout(timeoutMs)
        def addr = java.net.InetAddress.getByName(ip)
        sock.send(new java.net.DatagramPacket(pkt, pkt.length, addr, 161))
        sock.receive(new java.net.DatagramPacket(new byte[512], 512))
        sock.close()
        return true  // any UDP response = SNMP port reachable
    } catch (java.net.SocketTimeoutException e) {
        return false  // no response within timeout
    } catch (e) {
        return false
    }
}

def runTest(proto, ip, pingMs, tcpMs, snmpMs) {
    switch (proto) {
        case "ping":    return pingOk(ip, pingMs)     ? "PASS" : "FAIL"
        case "snmp":    return snmpOk(ip, snmpMs)     ? "PASS" : "TIMEOUT"
        case "tcp-22":  return tcpOk(ip,  22, tcpMs)  ? "PASS" : "FAIL"
        case "tcp-80":  return tcpOk(ip,  80, tcpMs)  ? "PASS" : "FAIL"
        case "tcp-135": return tcpOk(ip, 135, tcpMs)  ? "PASS" : "FAIL"
        case "tcp-443": return tcpOk(ip, 443, tcpMs)  ? "PASS" : "FAIL"
        default:        return "?"
    }
}

// ── Run all devices in parallel ────────────────────────────────────────────────

def protoOrder = ["ping", "snmp", "tcp-135", "tcp-22", "tcp-80", "tcp-443"]
def protoLabel = ["tcp-135": "wmi", "tcp-22": "ssh", "tcp-80": "http", "tcp-443": "https"]
def allProtos = devices.collectMany { it.protocols }.unique()
    .sort { a, b ->
        def ai = protoOrder.indexOf(a); def bi = protoOrder.indexOf(b)
        (ai < 0 ? 999 : ai) <=> (bi < 0 ? 999 : bi)
    }
def colW  = Math.max(7, (allProtos.collect { (protoLabel[it] ?: it).length() }.max() ?: 4) + 2)
def nameW = Math.max(30, devices.collect { it.displayName.length() }.max() + 2)
def ipW   = Math.max(20, devices.collect { it.ip.length() }.max() + 2)

println "Testing ${devices.size()} devices (parallel)...\n"

def pool    = Executors.newFixedThreadPool(Math.min(devices.size(), 20))
def futures = devices.collect { d ->
    pool.submit({
        def res = [:]
        allProtos.each { proto ->
            res[proto] = d.protocols.contains(proto)
                ? runTest(proto, d.ip, PING_TIMEOUT_MS, TCP_TIMEOUT_MS, SNMP_TIMEOUT_MS)
                : "-"
        }
        return [name: d.displayName, ip: d.ip, res: res]
    } as Callable)
}
pool.shutdown()
pool.awaitTermination(120, TimeUnit.SECONDS)

// ── Print results ──────────────────────────────────────────────────────────────

def header = String.format("%-${nameW}s %-${ipW}s", "Device", "IP/Hostname")
allProtos.each { header += String.format("  %-${colW}s", protoLabel[it] ?: it) }
println header
println "-" * header.length()

def failures = []
futures.eachWithIndex { f, i ->
    def r   = f.get()
    def row = String.format("%-${nameW}s %-${ipW}s", r.name.take(nameW - 1), r.ip.take(ipW - 1))
    allProtos.each { proto ->
        def result = r.res[proto]
        row += String.format("  %-${colW}s", result)
        if (result == "FAIL") failures << "${r.name}  ${protoLabel[proto] ?: proto}"
    }
    println row
}

println ""
if (failures) {
    println "FAILURES — investigate before adding this collector to the group:"
    failures.each { println "  - $it" }
    println ""
    println "snmp TIMEOUT may mean wrong community rather than unreachable — check snmp.community in LM."
    println "wmi PASS only confirms TCP 135 (RPC endpoint mapper); WMI uses dynamic high ports (49152-65535) too."
} else {
    println "All checks passed. Collector appears ready to join the auto-balance group."
}
