# elm bash completion — generated by 'make render', installed by 'make completion'
# Do not edit directly; edit _jnja/elm-completion.bash.j2 instead.
#
# Hybrid approach:
#   - Command names: completed statically from the baked-in list (CamelCase correct)
#   - Flags and values: completed dynamically via Click (_ELM_COMPLETE=complete)
#
# To regenerate after adding commands: make render && make completion

_elm_completion() {
    local cur="${COMP_WORDS[COMP_CWORD]}"

    # Complete command name statically to preserve CamelCase
    if [[ $COMP_CWORD -eq 1 && "$cur" != -* ]]; then
        local commands="{{ commands | sort(attribute='command') | unique(attribute='command') | map(attribute='command') | join(' ') }}"
        COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
        return 0
    fi

    # Fall back to dynamic completion for flags and values
    # IFS=$'\n' scoped here so compgen -W above uses default word splitting
    local IFS=$'\n'
    COMPREPLY=( $( env COMP_WORDS="${COMP_WORDS[*]}" \
                   COMP_CWORD=$COMP_CWORD \
                   _ELM_COMPLETE=complete $1 ) )
    return 0
}

_elm_completion_setup() {
    local COMPLETION_OPTIONS=""
    local BASH_VERSION_ARR=(${BASH_VERSION//./ })
    # Only BASH version 4.4 and later have the nosort option.
    if [ ${BASH_VERSION_ARR[0]} -gt 4 ] || ([ ${BASH_VERSION_ARR[0]} -eq 4 ] && [ ${BASH_VERSION_ARR[1]} -ge 4 ]); then
        COMPLETION_OPTIONS="-o nosort"
    fi
    complete $COMPLETION_OPTIONS -F _elm_completion elm
}

_elm_completion_setup
